+void processPendingCloseRequests(void* /*data*/)
+{
+    std::vector<CloseRequest*> localQueue;
+    {
+        std::lock_guard<std::mutex> lk(gCloseQueueMutex);
+        localQueue.swap(gCloseQueue);
+    }
+
+    for (auto* req : localQueue) {
+        if (req && req->client) {
+            closeStream(req->client, 1);  // Execute in live555 thread
+        }
+
+        if (req) {
+            std::lock_guard<std::mutex> lk(req->mtx);
+            req->done = true;
+            req->cv.notify_one();
+        }
+    }
+}
+
+int requestCloseOnRtspThread(RTSPClient* client)
+{
+    if (client == NULL || env == NULL) return -1;
+    if (gCloseClientTrigger == 0) return -1;
+
+    CloseRequest req;
+    req.client = client;
+
+    {
+        std::lock_guard<std::mutex> lk(gCloseQueueMutex);
+        gCloseQueue.push_back(&req);
+    }
+
+    env->taskScheduler().triggerEvent(gCloseClientTrigger, NULL);
+
+    // Wait for the event loop thread to finish executing closeStream(client)
+    std::unique_lock<std::mutex> lk(req.mtx);
+    req.cv.wait(lk, [&req] { return req.done; });
+
+    return 0;
+}
